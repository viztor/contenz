# Turborepo cache
.turbo/

# Build output
packages/*/dist/

# Node modules (if installed locally)
node_modules/

# E2E fixture output (generated by running CLI in packages/e2e/fixtures/*)
packages/e2e/fixtures/*/generated/
packages/e2e/fixtures/*/contenz.coverage.md
packages/e2e/fixtures/*/content.coverage.md

# Test coverage output
packages/*/coverage/

# Local Codex environment metadata
.codex/

# Root-level coverage output
coverage/

# Local planning drafts
Plan.md
Roadmap.optimized.md
