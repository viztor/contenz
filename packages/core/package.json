{
  "name": "@contenz/core",
  "version": "0.1.0",
  "description": "Content validation and codegen from MDX/Markdown with Zod",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js",
      "default": "./dist/api.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "format": "biome format --write src",
    "check": "biome check src",
    "knip": "knip"
  },
  "dependencies": {
    "zod": "^4.3.6",
    "globby": "^16.1.1",
    "picocolors": "^1.1.1",
    "tsx": "^4.21.0",
    "p-map": "^7.0.4"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.1",
    "@vitest/coverage-istanbul": "^4.1.1",
    "@biomejs/biome": "^2.4.8",
    "tsup": "^8.5.1",
    "knip": "^6.0.4"
  }
}