{
  "name": "@contenz/cli",
  "version": "0.1.0",
  "description": "CLI for contenz (content validation and codegen)",
  "license": "MPL-2.0",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "contenz",
    "cli",
    "content",
    "markdown",
    "mdx"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "contenz": "./bin/run.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contenz/core": "^0.1.0",
    "citty": "^0.2.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1"
  }
}